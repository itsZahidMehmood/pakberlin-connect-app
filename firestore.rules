rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entities Validation ---
    
    function isValidUser(data) {
      return data.uid == request.auth.uid 
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && (data.age == null || (data.age is number && data.age >= 18 && data.age <= 120))
        && data.city == "Berlin"
        && (data.bio == null || (data.bio is string && data.bio.size() <= 1000))
        && (data.interests == null || (data.interests is list && data.interests.size() <= 20))
        && (data.profilePic == null || (data.profilePic is string && data.profilePic.size() <= 2048));
    }

    function isValidFriendRequest(data) {
      return data.fromUid == request.auth.uid
        && isValidId(data.toUid)
        && data.status in ['pending', 'accepted', 'rejected']
        && data.createdAt == request.time;
    }

    function isValidMessage(data) {
      return data.senderId == request.auth.uid
        && data.text is string && data.text.size() > 0 && data.text.size() <= 5000
        && data.createdAt == request.time;
    }

    // --- Rules ---

    // Users
    match /users/{uid} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.city == "Berlin";
      allow create: if isOwner(uid) && isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isOwner(uid) && isValidUser(incoming()) 
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'age', 'bio', 'interests', 'profilePic', 'neighborhood', 'updatedAt'])
        && incoming().updatedAt == request.time;
    }

    // Friend Requests
    match /friend_requests/{requestId} {
      allow read: if isSignedIn() && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
      allow create: if isSignedIn() && isValidFriendRequest(incoming());
      allow update: if isSignedIn() 
        && (resource.data.toUid == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status']))
        || (resource.data.fromUid == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status']));
    }

    // Matches
    match /matches/{matchId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.users;
      // Matches are typically created by a cloud function or when a friend request is accepted
      // For simplicity in this demo, we allow create if the user is one of the participants
      allow create: if isSignedIn() && request.auth.uid in incoming().users;
      allow update: if isSignedIn() && request.auth.uid in existing().users
        && incoming().diff(existing()).affectedKeys().hasOnly(['lastMessage', 'lastMessageAt']);
      
      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.users;
        allow create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.users && isValidMessage(incoming());
      }
    }
  }
}
