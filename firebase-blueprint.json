{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Details about a PakBerlin Connect user",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "age": { "type": "number" },
        "city": { "type": "string", "enum": ["Berlin"] },
        "neighborhood": { "type": "string" },
        "bio": { "type": "string" },
        "interests": { "type": "array", "items": { "type": "string" } },
        "profilePic": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "city"]
    },
    "FriendRequest": {
      "title": "Friend Request",
      "description": "A request to connect between two users",
      "type": "object",
      "properties": {
        "fromUid": { "type": "string" },
        "toUid": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fromUid", "toUid", "status"]
    },
    "Match": {
      "title": "Match",
      "description": "A confirmed connection between two users",
      "type": "object",
      "properties": {
        "users": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Message": {
      "title": "Chat Message",
      "description": "A message sent in a match",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "Collection of user profiles"
    },
    "/friend_requests/{requestId}": {
      "schema": "FriendRequest",
      "description": "Inbound and outbound friend requests"
    },
    "/matches/{matchId}": {
      "schema": "Match",
      "description": "Active connections for chat"
    },
    "/matches/{matchId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Real-time chat messages within a match"
    }
  }
}
